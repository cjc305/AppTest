root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 130

[*.{kt,kts}]
ktlint_standard_no-wildcard-imports = enabled
ktlint_standard_filename = disabled
ktlint_standard_max-line-length = enabled
ktlint_standard_function-naming = enabled
# Compose @Composable functions use PascalCase — let detekt handle, disable ktlint clash
ktlint_function_naming_ignore_when_annotated_with = Composable, Test, ParameterizedTest, RepeatedTest, TestFactory
ktlint_code_style = intellij_idea

[*.{xml,gradle,properties}]
indent_size = 4

[*.{json,yml,yaml,md}]
indent_size = 2
